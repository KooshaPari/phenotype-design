{
  "name": "@kooshapari/design",
  "version": "1.0.1",
  "description": "Keycap palette \u2014 shared design tokens, VitePress theme, and style guide for Phenotype projects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./css/keycap-palette.css": "./css/keycap-palette.css",
    "./css/vitepress-theme.css": "./css/vitepress-theme.css",
    "./css/components.css": "./css/components.css",
    "./tokens": "./dist/tokens.js",
    "./vitepress": "./dist/vitepress.js"
  },
  "files": [
    "css/",
    "dist/",
    "tokens/"
  ],
  "scripts": {
    "build": "tsc && cp -r css dist/css",
    "dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "oxlint",
    "format": "oxfmt --write ."
  },
  "dependencies": {},
  "devDependencies": {
    "oxlint": "latest",
    "typescript": "latest",
    "vitepress": "latest",
    "vue": "latest"
  },
  "keywords": [
    "phenotype",
    "design-system",
    "keycap",
    "vitepress-theme",
    "design-tokens"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KooshaPari/phenotype-design"
  },
  "packageManager": "bun"
}
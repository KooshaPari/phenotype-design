{
  "name": "@kooshapari/design",
  "version": "1.0.1",
  "description": "Keycap palette — shared design tokens, VitePress theme, and style guide for Phenotype projects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./css/keycap-palette.css": "./css/keycap-palette.css",
    "./css/vitepress-theme.css": "./css/vitepress-theme.css",
    "./css/components.css": "./css/components.css",
    "./tokens": "./dist/tokens.js",
    "./vitepress": "./dist/vitepress.js"
  },
  "files": [
    "css/",
    "dist/",
    "tokens/"
  ],
  "scripts": {
    "build": "tsc && cp -r css dist/css",
    "dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@phenotype/docs": "^0.1.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "oxlint": "latest",
    "typescript": "latest",
    "vitepress": "latest",
    "vitest": "^4.1.2",
    "vue": "latest"
  },
  "overrides": {
    "brace-expansion": "5.0.5",
    "esbuild": "0.27.4"
  },
  "keywords": [
    "phenotype",
    "design-system",
    "keycap",
    "vitepress-theme",
    "design-tokens"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KooshaPari/phenotype-design"
  },
  "packageManager": "bun"
}
